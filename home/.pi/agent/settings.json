{
  "lastChangelogVersion": "0.74.0",
  "defaultProvider": "anthropic",
  "defaultModel": "claude-opus-4-7",
  "hideThinkingBlock": false,
  "theme": "light",
  "defaultThinkingLevel": "xhigh",
  "compaction": {
    "enabled": true
  },
  "retry": {
    "maxRetries": 10
  },
  "steeringMode": "all",
  "packages": [
    "npm:pi-caffeinate",
    "npm:pi-code-rollback",
    "npm:pi-session-search",
    "npm:pi-subdir-context",
    "npm:pi-timer",
    {
      "source": "npm:pi-web-access",
      "skills": [
        "-skills/librarian/SKILL.md"
      ]
    },
    {
      "source": "git:github.com/umputun/revdiff",
      "extensions": [
        "-plugins/pi/extensions/revdiff-post-edit.ts"
      ],
      "skills": []
    },
    {
      "source": "npm:mitsupi",
      "extensions": [
        "extensions/notify.ts"
      ],
      "skills": [],
      "themes": []
    }
  ],
  "warnings": {
    "anthropicExtraUsage": false
  },
  "enableInstallTelemetry": false
}

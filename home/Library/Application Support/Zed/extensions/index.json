  "themes": {
    "Github Dark": {
      "extension": "github-theme",
      "path": "themes/github_theme.json"
    },
    "Github Dark Colorblind": {
      "extension": "github-theme",
      "path": "themes/github_theme.json"
    },
    "Github Dark Dimmed": {
      "extension": "github-theme",
      "path": "themes/github_theme.json"
    },
    "Github Dark High Contrast": {
      "extension": "github-theme",
      "path": "themes/github_theme.json"
    },
    "Github Dark Tritanopia": {
      "extension": "github-theme",
      "path": "themes/github_theme.json"
    },
    "Github Light": {
      "extension": "github-theme",
      "path": "themes/github_theme.json"
    },
    "Github Light Colorblind": {
      "extension": "github-theme",
      "path": "themes/github_theme.json"

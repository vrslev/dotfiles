  "icon_themes": {},
  "languages": {
    "Fish": {
      "extension": "fish",
      "path": "languages/fish",
      "matcher": {
        "path_suffixes": [
          "fish"
        ],
        "first_line_pattern": "^#!.*\\bfish\\b"
      },
      "hidden": false,
      "grammar": "fish"
    },
    "GritQL": {
      "extension": "biome",
      "path": "languages/grit",
      "matcher": {
        "path_suffixes": [
          "grit"
        ],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "gritql"
    },
    "HTML": {
      "extension": "html",
      "path": "languages/html",
      "matcher": {
        "path_suffixes": [
          "html",
          "htm",
          "shtml"
        ],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "html"
    },
    "Just": {
      "extension": "just",
      "path": "languages/just",
      "matcher": {
        "path_suffixes": [
          "justfile",
          "Justfile",
          "JUSTFILE",
          "just"
        ],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "just"
    },
    "TOML": {
      "extension": "toml",
      "path": "languages/toml",
      "matcher": {
        "path_suffixes": [
          "Cargo.lock",
          "toml",
          "Pipfile",
          "uv.lock"
        ],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "toml"
    }
  }
}
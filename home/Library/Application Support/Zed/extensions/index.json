{
  "extensions": {
    "biome": {
      "manifest": {
        "id": "biome",
        "name": "Biome",
        "version": "0.2.2",
        "schema_version": 1,
        "description": "Biome support for Zed",
        "repository": "https://github.com/biomejs/biome-zed",
        "authors": [
          "biomejs <biomejs.dev>"
        ],
        "lib": {
          "kind": "Rust",
          "version": "0.7.0"
        },
        "themes": [],
        "icon_themes": [],
        "languages": [
          "languages/grit"
        ],
        "grammars": {
          "gritql": {
            "repository": "https://github.com/honeycombio/tree-sitter-gritql",
            "rev": "3a48815250680e85a44b3ab2fd74031ef3c66b7d",
            "path": null
          }
        },
        "language_servers": {
          "biome": {
            "language": "JavaScript",
            "languages": [
              "JavaScript",
              "JSX",
              "TypeScript",
              "TSX",
              "Vue.js",
              "Astro",
              "Svelte",
              "JSON",
              "JSONC",
              "CSS",
              "GraphQL",
              "HTML"
            ],
            "language_ids": {
              "JSONC": "jsonc",
              "Astro": "astro",
              "HTML": "html",
              "Svelte": "svelte",
              "TypeScript": "typescript",
              "JSON": "json",
              "GraphQL": "graphql",
              "JavaScript": "javascript",
              "CSS": "css",
              "Vue.js": "vuejs",
              "JSX": "javascriptreact",
              "TSX": "typescriptreact"
            },
            "code_action_kinds": [
              "quickfix"
            ]
          }
        },
        "context_servers": {},
        "agent_servers": {},
        "slash_commands": {},
        "snippets": null,
        "capabilities": []
      },
      "dev": false
    },

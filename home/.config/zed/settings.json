// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
	// "assistant": {
	// 	"default_model": {
	// 		"provider": "ollama",
	// 		"model": "llama3.1:latest"
	// 	},
	// 	"version": "2"
	// },
	"ui_font_weight": 400.0,
	"ui_font_family": ".SystemUIFont",
	"buffer_font_weight": 400.0,
	"buffer_font_family": "FiraCode Nerd Font",
	"base_keymap": "VSCode",
	"features": {
		"edit_prediction_provider": "none"
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	"ui_font_size": 14.0,
	"buffer_font_size": 14.0,
	"theme": {
		"mode": "system",
		"light": "Github Light",
		"dark": "Github Dark"
	},
	"autosave": {
		"after_delay": {
			"milliseconds": 300
		}
	},
	"show_call_status_icon": false,
	"terminal": {
		"font_family": "FiraCode Nerd Font",
		"copy_on_select": true,
		"font_size": 14
	},
	"format_on_save": "on",
	"diagnostics": {
		"inline": {
			"enabled": true,
			"max_severity": "hint"
		}
	},
	"scrollbar": {
		"diagnostics": "all"
	},
	"project_panel": {
		"dock": "right",
		"file_icons": true,
		"folder_icons": true,
		"git_status": true
	},
	"outline_panel": {
		"buttons": true,
		"dock": "right"
	},
	"toolbar": {
		"breadcrumbs": true,
		"quick_actions": true
	},
	"relative_line_numbers": "disabled",
	"soft_wrap": "none",
	"confirm_quit": false,
	"show_whitespaces": "none",
	"files": {
		"exclude": {
			"**/__pycache__": true,
			"**/.coverage*": true,
			"**/.mypy_cache": true,
			"**/.pytest_cache": true,
			"**/.ruff_cache": true,
			"**/coverage.xml": true,
			"**/.git": true,
			"**/.DS_Store": true,
			"**/node_modules": true,
			"**/target/debug": true,
			"**/target/release": true
		}
	},
	"languages": {
		"Python": {
			"language_servers": [
				"ty",
				"!basedpyright",
				"ruff",
				"pylsp"
			],
			"code_actions_on_format": {
				"source.organizeImports.ruff": true,
				"source.fixAll.ruff": true
			},
			"formatter": [
				{
					"language_server": {
						"name": "ruff"
					}
				}
			]
		},
		"JavaScript": {
			"language_servers": [
				"biome",
				"typescript-language-server"
			],
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			},
			"formatter": [
				{
					"language_server": {
						"name": "biome"
					}
				}
			]
		},
		"TypeScript": {
			"language_servers": [
				"biome",
				"typescript-language-server"
			],
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			},
			"formatter": [
				{
					"language_server": {
						"name": "biome"
					}
				}
			]
		},
		"JSX": {
			"language_servers": [
				"biome",
				"typescript-language-server"
			],
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			},
			"formatter": [
				{
					"language_server": {
						"name": "biome"
					}
				}
			]
		},
		"TSX": {
			"language_servers": [
				"biome",
				"typescript-language-server"
			],
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			},
			"formatter": [
				{
					"language_server": {
						"name": "biome"
					}
				}
			]
		},
		"JSON": {
			"language_servers": [
				"biome"
			],
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			},
			"formatter": [
				{
					"language_server": {
						"name": "biome"
					}
				}
			]
		},
		"JSONC": {
			"language_servers": [
				"biome"
			],
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			},
			"formatter": [
				{
					"language_server": {
						"name": "biome"
					}
				}
			]
		},
		"CSS": {
			"language_servers": [
				"biome"
			],
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			},
			"formatter": [
				{
					"language_server": {
						"name": "biome"
					}
				}
			]
		},
		"YAML": {
			"language_servers": [
				"yaml-language-server"
			]
		},
		"Dockerfile": {
			"language_servers": [
				"dockerfile-language-server"
			]
		}
	},
	"lsp": {
		"ruff": {
			"initialization_options": {
				"settings": {
					"lint": {
						"ignore": [
							"F841",
							"T201",
							"RUF100"
						]
					}
				}
			}
		},
		"pylsp": {
			"initialization_options": {
				"settings": {
					"python": {
						"pythonPath": ".venv/bin/python"
					}
				}
			},
			"settings": {
				"plugins": {
					"rope": {
						"enabled": false
					},
					"pylint": {
						"enabled": false
					},
					"pycodestyle": {
						"enabled": false
					},
					"jedi_symbols": {
						"enabled": false
					},
					"jedi_definition": {
						"enabled": false
					},
					"jedi_references": {
						"enabled": false
					},
					"jedi_hover": {
						"enabled": false
					},
					"jedi_completion": {
						"enabled": false
					},
					"jedi_signature_help": {
						"enablded": false
					},
					"pylsp_mypy": {
						"enabled": true,
						"dmypy": true,
						"overrides": [
							"--python-executable",
							".venv/bin/python",
							true
						]
					}
				}
			}
		}
	}
}

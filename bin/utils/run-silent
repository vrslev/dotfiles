#!/bin/bash

# Override just command to implement context-efficient backpressure (checkbot pattern)
# Only show output when there are issues, suppress when everything is fine
# Based on HumanLayer's pattern: https://www.humanlayer.dev/blog/context-efficient-backpressure

# Help function
show_help() {
    echo "Usage: run-silent [OPTIONS] COMMAND"
    echo ""
    echo "Run a command silently, only showing output when it fails."
    echo ""
    echo "Options:"
    echo "  -h, --help    Show this help message and exit"
    echo ""
    echo "Examples:"
    echo "  run-silent npm test"
    echo "  run-silent just lint"
    echo ""
    echo "The script will:"
    echo "  - Show a checkmark (✓) and exit code 0 if the command succeeds"
    echo "  - Show a cross (✗), the failed command, and its output if it fails"
}

# Check for help flags or no arguments
if [[ "$#" -eq 0 || "$1" == "-h" || "$1" == "--help" ]]; then
    show_help
    exit 0
fi

command="$@"
tmp_file=$(mktemp)

if eval "$command" > "$tmp_file" 2>&1; then
    printf "✓ %s\n" "$command"
    rm -f "$tmp_file"
    exit 0
else
    exit_code=$?
    printf "✗ %s\n" "$command"
    cat "$tmp_file"
    rm -f "$tmp_file"
    exit $exit_code
fi

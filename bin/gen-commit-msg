#!/opt/homebrew/bin/mise x uv -- uv run --script
# /// script
# requires-python = ">=3.14"
# dependencies = [
#     "openai",
# ]
# ///
import os
import subprocess
import sys

from openai import OpenAI


def log(content: str) -> None:
    print(f"{commit_id}: {content}", file=sys.stderr)


commit_id = sys.argv[1]
previous_commit_message = subprocess.run(
    ["git", "log", "-1", "--pretty=%B", commit_id],
    capture_output=True,
    text=True,
    check=True,
).stdout.strip()
if len(previous_commit_message) > 7:
    log(f"skip, len({previous_commit_message=}) > 7")
    sys.exit(0)

commit_diff = subprocess.run(
    ["git", "diff-tree", "--no-commit-id", "-p", "-r", commit_id],
    capture_output=True,
    text=True,
    check=True,
).stdout
if not commit_diff.strip():
    log("skip, empty commit")
    sys.exit(0)
max_diff_chars = 32 * 1024
if len(commit_diff) > max_diff_chars:
    commit_diff = commit_diff[:max_diff_chars]
    log(f"truncating commit diff — it exceeds {max_diff_chars=}")

try:
    client = OpenAI(
        api_key=os.environ["OPENAI_API_KEY"],
        base_url=os.environ["OPENAI_BASE_URL"],
        timeout=5,
        max_retries=1,
    )
    response = client.chat.completions.create(
        model=os.environ["OPENAI_MODEL"],
        messages=[
            {
                "role": "system",
                "content": "Generate a concise and descriptive commit message for the git diff. Make sure first character of your answer is a letter. Do not use template words such as 'adjust'. Keep it really short, no more than 50 characters!",
            },
            {
                "role": "user",
                "content": commit_diff,
            },
        ],
        max_tokens=100,
        temperature=0.5,
    )
    new_commit_message = response.choices[0].message.content.strip()
except Exception as exception:
    log(f"failed to generate commit message: {exception}")
    sys.stdout.write("Update")
else:
    sys.stdout.write(new_commit_message)

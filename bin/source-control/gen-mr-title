#!/usr/bin/env uv run --script
# /// script
# requires-python = ">=3.14"
# dependencies = [
#     "openai",
# ]
# ///
import os
import subprocess
import sys

from openai import OpenAI


def log(content: str) -> None:
    print(f"gen-mr-title: {content}", file=sys.stderr)


def get_default_branch() -> str:
    """Get the default branch name, trying different common names"""
    # Try to get the default branch from remote
    result = subprocess.run(
        ["git", "symbolic-ref", "refs/remotes/origin/HEAD"],
        capture_output=True,
        text=True,
    )
    if result.returncode == 0:
        return result.stdout.strip().split("/")[-1]

    # Fallback to common names
    for branch in ["main", "master"]:
        result = subprocess.run(
            ["git", "rev-parse", "--verify", branch],
            capture_output=True,
            text=True,
        )
        if result.returncode == 0:
            return branch

    # If we can't determine, default to 'main'
    return "main"


def parse_branch_name(ref: str) -> str:
    """Extract branch name from Git ref (e.g., refs/heads/main -> main, origin/main -> main)"""
    # Handle refs/heads/branch_name
    if ref.startswith("refs/heads/"):
        return ref[len("refs/heads/"):]
    
    # Handle origin/branch_name or other remote/branch_name formats
    if "/" in ref and not ref.startswith("refs/"):
        parts = ref.split("/")
        # If it looks like remote/branch, return branch part
        # But be careful not to cut off legitimate branch names with slashes
        if len(parts) >= 2 and parts[0] in ("origin", "upstream"):
            return "/".join(parts[1:])
        
    # For all other cases, return as is
    return ref


def main():
    try:
        # Get branch name for context
        branch_name = subprocess.run(
            ["git", "rev-parse", "--abbrev-ref", "HEAD"],
            capture_output=True,
            text=True,
            check=True,
        ).stdout.strip()

        # Get the configured merge target branch for this branch (base branch for MR)
        result = subprocess.run(
            ["git", "config", f"branch.{branch_name}.merge"],
            capture_output=True,
            text=True,
        )
        if result.returncode == 0 and result.stdout.strip():
            # Format is 'refs/heads/main' → extract branch name properly
            target_branch = parse_branch_name(result.stdout.strip())
        else:
            # Fallback: use upstream branch if set
            result = subprocess.run(
                ["git", "rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{u}"],
                capture_output=True,
                text=True,
            )
            if result.returncode == 0:
                target_branch = parse_branch_name(result.stdout.strip())
            else:
                # Final fallback: default branch
                target_branch = get_default_branch()

        # Find the common ancestor (merge base) between current branch and target branch
        merge_base = subprocess.run(
            ["git", "merge-base", branch_name, target_branch],
            capture_output=True,
            text=True,
        )
        if merge_base.returncode != 0:
            log(f"failed to find merge base between '{branch_name}' and '{target_branch}'")
            sys.exit(1)

        merge_base_hash = merge_base.stdout.strip()

        # Get full diff of changes in current branch relative to base
        diff = subprocess.run(
            ["git", "diff", f"{merge_base_hash}..HEAD"],
            capture_output=True,
            text=True,
            check=True,
        ).stdout.strip()

        # If no diff, exit early
        if not diff:
            log("no changes detected between base and current branch")
            sys.exit(1)

        # Use the full diff as context instead of commit messages
        diff_text = diff

        # No need to split or count commits — we're using the full diff
        log(f"found {len(diff_text.splitlines())} lines of changes in this branch")

        # Extract issue number from branch name
        issue_result = subprocess.run(
            ["get-work-issue-no", branch_name],
            capture_output=True,
            text=True,
        )
        issue_number = issue_result.stdout.strip()

        jira_context = ""
        if issue_number:
            log(f"found issue number: {issue_number}")
            # Get Jira issue details
            jira_result = subprocess.run(
                [
                    "jira",
                    "issue",
                    "view",
                    issue_number,
                    "--plain",
                    "--comments",
                    "1000",
                ],
                capture_output=True,
                text=True,
            )
            if jira_result.returncode == 0:
                jira_context = (
                    f"\n\n# Jira Issue: {issue_number}\n{jira_result.stdout.strip()}"
                )
                log(f"added Jira issue context for {issue_number}")
            else:
                log(
                    f"failed to get Jira issue details for {issue_number}: {jira_result.stderr}"
                )

        client = OpenAI(
            api_key=os.environ["SCRIPTS_OPENAI_API_KEY"],
            base_url=os.environ["SCRIPTS_OPENAI_BASE_URL"],
            timeout=5,
            max_retries=1,
        )

        response = client.chat.completions.create(
            model=os.environ["SCRIPTS_OPENAI_MODEL"],
            messages=[
                {
                    "role": "system",
                    "content": "Generate a concise and descriptive merge request title based on the git commits. Make sure first character of your answer is a letter. Do not use template words such as 'adjust'. Keep it really short, no more than 50 characters! Focus on the overall theme of the changes rather than individual commits. If a Jira issue is provided, consider the issue description and comments when generating the title.",
                },
                {
                    "role": "user",
                    "content": f"# Branch name: {branch_name}{jira_context}\n\n# Changes in this branch:\n{diff_text}",
                },
            ],
            max_tokens=100,
            temperature=0.5,
        )

        title = response.choices[0].message.content.strip()
        sys.stdout.write(title)

    except Exception as exception:
        log(f"failed to generate MR title: {exception}")
        sys.exit(1)


if __name__ == "__main__":
    main()
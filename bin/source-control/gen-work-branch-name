#!/usr/bin/env uv run --script
# /// script
# requires-python = ">=3.14"
# dependencies = [
#     "openai",
# ]
# ///
import os
import re
import subprocess
import sys
import traceback
from typing import Final, Optional

from openai import OpenAI


def log(content: str) -> None:
    print(f"gen-work-branch-name: {content}", file=sys.stderr)


def get_issue_number(branch_name: str) -> Optional[str]:
    result = subprocess.run(
        ["get-work-issue-no", branch_name],
        capture_output=True,
        text=True,
    )
    issue_number = result.stdout.strip()
    return issue_number if issue_number else None


def get_issue_details(issue_number: str) -> Optional[str]:
    result = subprocess.run(
        [
            "jira",
            "issue",
            "view",
            issue_number,
            "--plain",
        ],
        capture_output=True,
        text=True,
    )
    if result.returncode == 0:
        return result.stdout.strip()
    else:
        log(f"failed to get Jira issue details for {issue_number}: {result.stderr}")
        return None


def get_current_branch() -> str:
    result = subprocess.run(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout.strip()


def main():
    try:
        if len(sys.argv) > 1 and sys.argv[1] in ["--help", "-h"]:
            print("Usage: gen-work-branch-name ISSUE_NUMBER_OR_BRANCH")
            print("Generate a branch name based on Jira issue details.")
            print("ISSUE_NUMBER_OR_BRANCH can be:")
            print("  - An issue number (e.g., ABC-123)")
            print(
                "  - A branch name containing an issue number (e.g., feature/ABC-123-fix-bug)"
            )
            return

        if len(sys.argv) < 2:
            log("issue number or branch name is required as first argument")
            print("Usage: gen-work-branch-name ISSUE_NUMBER_OR_BRANCH")
            sys.exit(1)

        input_arg = sys.argv[1]
        issue_number = get_issue_number(input_arg)

        if not issue_number:
            log(f"no valid issue number found in '{input_arg}'")
            sys.exit(1)

        branch_name = get_current_branch()

        log(f"found issue number: {issue_number}")

        issue_details = get_issue_details(issue_number)
        if not issue_details:
            log(f"failed to get details for issue {issue_number}")
            sys.exit(1)

        client = OpenAI(
            api_key=os.environ["SCRIPTS_OPENAI_API_KEY"],
            base_url=os.environ["SCRIPTS_OPENAI_BASE_URL"],
            timeout=5,
            max_retries=1,
        )

        response = client.chat.completions.create(
            model=os.environ["SCRIPTS_OPENAI_MODEL"],
            messages=[
                {
                    "role": "system",
                    "content": "Generate a git branch name based on the Jira issue. "
                    "Use the exact format: (feature|bugfix|hotfix)/ISSUE-KEY-short-description "
                    "Where: "
                    "- Prefix must be one of: feature, bugfix, hotfix "
                    "- ISSUE-KEY must be the exact issue key as provided (uppercase) "
                    "- Description must be in kebab-case (lowercase with hyphens) "
                    "- Example: feature/ABC-123-fix-login-issue "
                    "- Keep the description really short, no more than 3 words! "
                    "- Focus on the main purpose of the issue "
                    "- Do not use template words such as 'adjust' "
                    "- Only output the branch name, nothing else.",
                },
                {
                    "role": "user",
                    "content": f"# Jira Issue: {issue_number}\n{issue_details}",
                },
            ],
            max_tokens=100,
            temperature=0.5,
        )

        branch_name = response.choices[0].message.content.strip()

        # Split into prefix and rest
        parts = branch_name.split("/", 1)
        if len(parts) != 2:
            # If no prefix, add 'feature' prefix
            branch_name = f"feature/{branch_name}"
            parts = branch_name.split("/", 1)

        prefix, rest = parts[0], parts[1]

        # Ensure prefix is one of the allowed values
        allowed_prefixes: Final = ("feature", "bugfix", "hotfix")
        if prefix not in allowed_prefixes:
            prefix = "feature"

        # Find the issue number part (e.g., "ABC-123")
        issue_match = re.search(r"^([A-Z]+-[0-9]+)", rest)
        if not issue_match:
            sys.stdout.write(f"{prefix}/{issue_number}")
            return

        issue_key = issue_match.group(1)
        description = rest[len(issue_key) :].lstrip("-")

        # Ensure description is in kebab-case (lowercase with hyphens only)
        description = re.sub(r"[^a-zA-Z0-9\-]", "-", description)
        description = re.sub(r"-+", "-", description)
        description = description.strip("-")
        description = description.lower()

        # Reconstruct with proper format
        result_branch_name = f"{prefix}/{issue_key}"
        if description:
            result_branch_name += f"-{description}"

        sys.stdout.write(result_branch_name)

    except Exception as exception:
        log(f"failed to generate branch name: {exception}")
        traceback.print_exception(exception)
        sys.exit(1)


if __name__ == "__main__":
    main()

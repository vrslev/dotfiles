#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage: cai [options]

Stage changes, generate a commit message with pi, and commit.

Options:
  --staged                    Use current staged changes; do not run git add --all
  --push                      Run git push after committing
  --provider NAME             pi provider; defaults to gen-commit-msg
  --model PATTERN             pi model pattern/id; defaults to gen-commit-msg
  --thinking LEVEL            pi thinking level; defaults to gen-commit-msg
  --timeout SECONDS           pi generation timeout; defaults to PI_COMMIT_TIMEOUT or 60
  --max-diff-chars CHARS      diff chars sent to pi; defaults to PI_COMMIT_MAX_DIFF_CHARS or 32768
  --style STYLE               Commit style: mcga or concise; defaults to gen-commit-msg
  --list-models [SEARCH]      List models from pi providers/models config
  -h, --help                  Show this help
EOF
}

stage_changes=1
push_after_commit=0
generator_arguments=()

while (($#)); do
    case "$1" in
        --staged)
            stage_changes=0
            shift
            ;;
        --push)
            push_after_commit=1
            shift
            ;;
        --provider | --model | --thinking | --timeout | --max-diff-chars | --style)
            if (($# < 2)); then
                echo "cai: $1 requires a value" >&2
                exit 2
            fi
            generator_arguments+=("$1" "$2")
            shift 2
            ;;
        --provider=* | --model=* | --thinking=* | --timeout=* | --max-diff-chars=* | --style=*)
            generator_arguments+=("${1%%=*}" "${1#*=}")
            shift
            ;;
        --list-models)
            shift
            if (($#)) && [[ "$1" != -* ]]; then
                pi --list-models "$1"
            else
                pi --list-models
            fi
            exit 0
            ;;
        -h | --help)
            usage
            exit 0
            ;;
        *)
            echo "cai: unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if ((stage_changes)); then
    git add --all
fi

if git diff --cached --quiet --exit-code; then
    echo "cai: no staged changes" >&2
    exit 1
fi

retry_with_post_commit_hook=0
if ! commit_message="$(gen-commit-msg --staged "${generator_arguments[@]}")"; then
    echo "cai: generation failed; committing with placeholder 1" >&2
    commit_message=1
    retry_with_post_commit_hook=1
elif [[ -z "$commit_message" ]]; then
    echo "cai: empty message; committing with placeholder 1" >&2
    commit_message=1
    retry_with_post_commit_hook=1
fi

echo "cai: $commit_message" >&2
if ((retry_with_post_commit_hook)); then
    git commit -m "$commit_message"
else
    CAI_SKIP_POST_COMMIT=1 git commit -m "$commit_message"
fi

if ((push_after_commit)); then
    git push
fi

#!/usr/bin/env bash
git cai || true

branch_name="$(git rev-parse --abbrev-ref HEAD)"
work_issue_no="$(get-work-issue-no $branch_name)"

title=""
if [ -n "$1" ]; then
    if [ "$1" = "--use-last-commit-msg" ]; then
        title="$(git log -1 --pretty=%B | head -1)"
    else
        title="$1"
    fi
else
    title="$(gen-mr-title)"
fi

glab mr create --web --squash-before-merge --remove-source-branch --push \
    --description "" \
    --assignee "$(whoami)" \
    --title "$work_issue_no: $title"

#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage: create-glab-mr [--use-last-commit-msg | TITLE]

Create a GitLab merge request in the browser.

Arguments:
  TITLE                  Use TITLE as the merge request title
  --use-last-commit-msg  Use the last commit subject as the merge request title
  -h, --help             Show this help

Without TITLE, create-glab-mr uses gen-mr-title.
Issue prefix is added from the current branch when present.
EOF
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    usage
    exit 0
fi

cai || true

branch_name="$(git branch --show-current)"
work_issue_no="$(get-work-issue-no "$branch_name")"

title=""
if [ -n "${1:-}" ]; then
    if [ "$1" = "--use-last-commit-msg" ]; then
        title="$(git log -1 --pretty=%B | head -1)"
    else
        title="$1"
    fi
else
    title="$(gen-mr-title)"
fi

mr_title="$title"
if [ -n "$work_issue_no" ]; then
    mr_title="$work_issue_no: $title"
fi

glab mr create --web --squash-before-merge --remove-source-branch --push \
    --description "" \
    --assignee "$(whoami)" \
    --title "$mr_title"

#!/usr/bin/env -S uv run --python 3.13 --script
# pyright: strict
from __future__ import annotations

import argparse
import os
import re
import subprocess
import sys
import typing

DEFAULT_MAX_DIFF_CHARS: typing.Final = 32 * 1024
CONCISE_SYSTEM_PROMPT: typing.Final = (
    "You write git commit summaries. Output exactly one line, no quotes, no Markdown, no prefix, "
    "no trailing period. Start with a letter. Keep it under 50 characters. Use imperative mood. "
    "Do not use template words such as adjust."
)
CONCISE_USER_PROMPT: typing.Final = "Generate a concise and descriptive commit message for this git diff."
MCGA_SYSTEM_PROMPT: typing.Final = (
    "You write MCGA (Make Commits Great Again) git commit messages in English, styled like "
    "overconfident Donald Trump tweets. Output only the commit message, no quotes, no Markdown, "
    "no code fences. First line must be a conventional commit subject like `fix: auth CATASTROPHE "
    "— FIXED!`; choose feat, fix, docs, refactor, test, chore, build, ci, perf, or style. "
    "Then add a blank line and 2-5 short punchy English sentences. Use selective uppercase "
    "for emphasis. Be dramatic and funny, but base every claim on the diff. Do not mention "
    "Trump by name."
)
MCGA_USER_PROMPT: typing.Final = "Generate an MCGA-style commit message for this git diff."
THINKING_LEVELS: typing.Final = ("off", "minimal", "low", "medium", "high", "xhigh")
COMMIT_STYLES: typing.Final = ("concise", "mcga")


@typing.final
class ParsedArguments(typing.NamedTuple):
    commit_identifier: str | None
    staged: bool
    provider: str | None
    model: str | None
    thinking: str
    timeout_seconds: float
    max_diff_chars: int
    style: str


def parse_arguments(raw_arguments: list[str]) -> ParsedArguments:
    argument_parser = argparse.ArgumentParser(description="Generate a git commit message using pi.")
    argument_parser.add_argument("commit_identifier", nargs="?")
    argument_parser.add_argument("--staged", action="store_true", help="Generate from staged changes")
    argument_parser.add_argument("--provider", default=os.environ.get("PI_COMMIT_PROVIDER", "openai-codex"))
    argument_parser.add_argument("--model", default=os.environ.get("PI_COMMIT_MODEL", "gpt-5.3-codex-spark"))
    argument_parser.add_argument(
        "--thinking",
        choices=THINKING_LEVELS,
        default=os.environ.get("PI_COMMIT_THINKING", "low"),
    )
    argument_parser.add_argument("--timeout", type=float, default=float(os.environ.get("PI_COMMIT_TIMEOUT", "60")))
    argument_parser.add_argument(
        "--max-diff-chars",
        type=int,
        default=int(os.environ.get("PI_COMMIT_MAX_DIFF_CHARS", str(DEFAULT_MAX_DIFF_CHARS))),
    )
    argument_parser.add_argument("--style", choices=COMMIT_STYLES, default=os.environ.get("PI_COMMIT_STYLE", "concise"))
    namespace = argument_parser.parse_args(raw_arguments)
    commit_identifier = typing.cast(str | None, namespace.commit_identifier)
    staged = typing.cast(bool, namespace.staged)
    if staged and commit_identifier is not None:
        argument_parser.error("COMMIT_IDENTIFIER cannot be used with --staged")
    if not staged and commit_identifier is None:
        argument_parser.error("COMMIT_IDENTIFIER or --staged is required")

    return ParsedArguments(
        commit_identifier=commit_identifier,
        staged=staged,
        provider=typing.cast(str | None, namespace.provider),
        model=typing.cast(str | None, namespace.model),
        thinking=typing.cast(str, namespace.thinking),
        timeout_seconds=typing.cast(float, namespace.timeout),
        max_diff_chars=typing.cast(int, namespace.max_diff_chars),
        style=typing.cast(str, namespace.style),
    )


def write_log_message(label: str, content: str) -> None:
    print(f"{label}: {content}", file=sys.stderr)


def run_git_command(command_arguments: list[str]) -> str:
    return subprocess.run(
        ["git", *command_arguments],
        capture_output=True,
        text=True,
        check=True,
    ).stdout


def read_model_output_lines(raw_output: str) -> list[str]:
    output_lines = [line.strip() for line in raw_output.strip().splitlines() if not line.strip().startswith("```")]
    while output_lines and not output_lines[0]:
        output_lines.pop(0)
    while output_lines and not output_lines[-1]:
        output_lines.pop()
    if output_lines and re.fullmatch(r"(?i)commit message\s*: ?", output_lines[0]):
        output_lines.pop(0)
        while output_lines and not output_lines[0]:
            output_lines.pop(0)
    return output_lines


def clean_subject_line(subject_line: str) -> str:
    without_prefix = re.sub(r"(?i)^commit message\s*:\s*", "", subject_line)
    without_command = re.sub(r"(?i)^git commit -m\s+", "", without_prefix)
    without_bullet = re.sub(r"^[-*•]\s+", "", without_command)
    without_quotes = without_bullet.strip("`'\" ")
    return re.sub(r"\s+", " ", without_quotes).strip()


def clean_commit_message(raw_output: str, style: str) -> str:
    output_lines = read_model_output_lines(raw_output)
    if not output_lines:
        return ""
    subject_line = clean_subject_line(output_lines[0])
    if style == "concise":
        return subject_line.rstrip(".")

    cleaned_lines = [subject_line, *[re.sub(r"[ \t]+", " ", line).strip("`") for line in output_lines[1:]]]
    normalized_lines: list[str] = []
    previous_line_blank = False
    for line in cleaned_lines:
        if not line:
            if not previous_line_blank:
                normalized_lines.append("")
            previous_line_blank = True
            continue
        normalized_lines.append(line)
        previous_line_blank = False
    return "\n".join(normalized_lines).strip()


def get_prompts(style: str) -> tuple[str, str]:
    if style == "mcga":
        return MCGA_SYSTEM_PROMPT, MCGA_USER_PROMPT
    return CONCISE_SYSTEM_PROMPT, CONCISE_USER_PROMPT


def generate_with_pi(arguments: ParsedArguments, diff_content: str) -> str:
    system_prompt, user_prompt = get_prompts(arguments.style)
    pi_command = [
        "pi",
        "--no-session",
        "--no-tools",
        "--no-context-files",
        "--no-skills",
        "--no-prompt-templates",
        "--thinking",
        arguments.thinking,
    ]
    if arguments.provider is not None:
        pi_command.extend(["--provider", arguments.provider])
    if arguments.model is not None:
        pi_command.extend(["--model", arguments.model])
    pi_command.extend(["--system-prompt", system_prompt, "-p", user_prompt])

    completed_process = subprocess.run(
        pi_command,
        input=f"# Git diff\n{diff_content}",
        capture_output=True,
        text=True,
        timeout=arguments.timeout_seconds,
        check=False,
    )
    if completed_process.returncode != 0:
        error_output = completed_process.stderr.strip() or completed_process.stdout.strip()
        raise RuntimeError(error_output or f"pi exited with {completed_process.returncode}")

    commit_message = clean_commit_message(completed_process.stdout, arguments.style)
    if not commit_message:
        raise RuntimeError("empty model output")
    subject_line = commit_message.splitlines()[0]
    if re.match(r"^[A-Za-z]", subject_line) is None:
        raise RuntimeError(f"commit message subject must start with a letter: {subject_line!r}")
    return commit_message


def read_diff_content(arguments: ParsedArguments, label: str) -> str | None:
    if arguments.commit_identifier is not None:
        previous_message = run_git_command(["log", "-1", "--pretty=%B", arguments.commit_identifier]).strip()
        if previous_message == "Update":
            write_log_message(label, f"skip, previous_message={previous_message!r}")
            return None
        if len(previous_message) > 7:
            write_log_message(label, f"skip, len(previous_message={previous_message!r}) > 7")
            return None
        return run_git_command(["diff-tree", "--no-commit-id", "-p", "-r", arguments.commit_identifier])

    return run_git_command(["diff", "--cached", "--no-ext-diff"])


def execute_main() -> int:
    arguments = parse_arguments(sys.argv[1:])
    label = arguments.commit_identifier or "staged"
    try:
        diff_content = read_diff_content(arguments, label)
        if diff_content is None:
            return 0
        if not diff_content.strip():
            write_log_message(label, "skip, empty commit")
            return 0
        if len(diff_content) > arguments.max_diff_chars:
            write_log_message(label, f"truncating commit diff — it exceeds max_diff_chars={arguments.max_diff_chars}")
            diff_content = diff_content[: arguments.max_diff_chars]
        sys.stdout.write(generate_with_pi(arguments, diff_content))
    except (OSError, RuntimeError, subprocess.SubprocessError) as error:
        write_log_message(label, f"failed to generate commit message: {error}")
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(execute_main())
